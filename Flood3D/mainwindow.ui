   </rect>
  </property>
  <property name="windowTitle">
   <string>FloodSim GIS — Flood Simulation &amp; Terrain Analysis</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
QMainWindow, QWidget {
    background-color: #1a1d22;
    color: #c9d1d9;
    font-family: &quot;Segoe UI&quot;;
    font-size: 9pt;
}
QMenuBar {
    background-color: #2a2f38;
    color: #c9d1d9;
    border-bottom: 1px solid #111418;
    padding: 0px;
    spacing: 0px;
    font-size: 9pt;
}
QMenuBar::item {
    padding: 5px 12px;
    background: transparent;
}
QMenuBar::item:selected {
    background-color: #0078d4;
    color: #ffffff;
}
QMenuBar::item:pressed {
    background-color: #005fa3;
    color: #ffffff;
}
QMenu {
    background-color: #22262d;
    color: #c9d1d9;
    border: 1px solid #111418;
    padding: 3px 0px;
    font-size: 9pt;
}
QMenu::item {
    padding: 5px 30px 5px 16px;
}
QMenu::item:selected {
    background-color: #0078d4;
    color: #ffffff;
}
QMenu::separator {
    height: 1px;
    background: #2c313a;
    margin: 3px 8px;
}
QToolBar {
    background-color: #252930;
    border: none;
    border-bottom: 1px solid #111418;
    spacing: 2px;
    padding: 3px 6px;
}
QToolBar::separator {
    width: 1px;
    background-color: #2c313a;
    margin: 4px 5px;
}
QToolButton {
    background-color: transparent;
    color: #8b949e;
    border: 1px solid transparent;
    border-radius: 3px;
    padding: 3px 10px;
    font-size: 9pt;
    font-family: &quot;Segoe UI&quot;;
    min-width: 28px;
    min-height: 22px;
}
QToolButton:hover {
    background-color: #2e3440;
    border-color: #2c313a;
    color: #c9d1d9;
}
QToolButton:pressed {
    background-color: #0078d4;
    border-color: #005fa3;
    color: #ffffff;
}
QToolButton:checked {
    background-color: #1a3a5c;
    border-color: #0078d4;
    color: #4db8ff;
}
QStatusBar {
    background-color: #0069b8;
    color: #ffffff;
    font-size: 8.5pt;
    border-top: 1px solid #005fa3;
    padding: 0px 8px;
    min-height: 22px;
}
QStatusBar::item { border: none; }
QStatusBar QLabel {
    color: #ffffff;
    font-size: 8.5pt;
    background: transparent;
    padding: 0px 8px;
}
QDockWidget {
    color: #c9d1d9;
    font-size: 9pt;
}
QDockWidget::title {
    background-color: #181b20;
    color: #8b949e;
    text-align: left;
    padding: 4px 10px;
    border-bottom: 1px solid #111418;
    font-size: 8pt;
    font-weight: bold;
}
QDockWidget::close-button, QDockWidget::float-button {
    background: transparent;
    border: none;
    padding: 1px;
}
QSplitter::handle {
    background-color: #111418;
}
QSplitter::handle:horizontal { width: 2px; }
QSplitter::handle:vertical   { height: 2px; }
QSplitter::handle:hover      { background-color: #0078d4; }
QListWidget {
    background-color: #181b20;
    color: #8b949e;
    border: none;
    outline: none;
    font-size: 9pt;
    padding: 2px;
}
QListWidget::item {
    padding: 5px 10px;
    border-bottom: 1px solid #1a1d22;
    border-left: 2px solid transparent;
}
QListWidget::item:selected {
    background-color: #1a3a5c;
    color: #4db8ff;
    border-left: 2px solid #0078d4;
}
QListWidget::item:hover:!selected {
    background-color: #2e3440;
    color: #c9d1d9;
}
QTreeWidget {
    background-color: #181b20;
    color: #8b949e;
    border: none;
    outline: none;
    font-size: 9pt;
    show-decoration-selected: 1;
}
QTreeWidget::item {
    padding: 3px 4px;
    border-bottom: 1px solid #1a1d22;
}
QTreeWidget::item:selected {
    background-color: #1a3a5c;
    color: #4db8ff;
    border-left: 2px solid #0078d4;
}
QTreeWidget::item:hover:!selected {
    background-color: #2e3440;
    color: #c9d1d9;
}
QTreeWidget::branch { background: #181b20; }
QHeaderView::section {
    background-color: #181b20;
    color: #4a5568;
    font-size: 8pt;
    font-weight: bold;
    padding: 3px 8px;
    border: none;
    border-bottom: 1px solid #111418;
}
QCheckBox {
    color: #8b949e;
    spacing: 7px;
    font-size: 9pt;
    padding: 2px 0px;
}
QCheckBox::indicator {
    width: 13px;
    height: 13px;
    border: 1px solid #546070;
    border-radius: 2px;
    background-color: #1a1d22;
}
QCheckBox::indicator:checked {
    background-color: #0078d4;
    border-color: #0078d4;
}
QCheckBox::indicator:hover { border-color: #0078d4; }
QCheckBox:hover { color: #c9d1d9; }
QLabel {
    color: #8b949e;
    font-size: 9pt;
    background: transparent;
}
QSlider::groove:horizontal {
    border: none;
    height: 4px;
    background: #2c313a;
    border-radius: 2px;
}
QSlider::handle:horizontal {
    background: #0078d4;
    border: 2px solid #005fa3;
    width: 12px;
    height: 12px;
    margin: -5px 0;
    border-radius: 7px;
}
QSlider::handle:horizontal:hover { background: #4db8ff; }
QSlider::sub-page:horizontal {
    background: #0078d4;
    border-radius: 2px;
}
QPlainTextEdit {
    background-color: #0d1117;
    color: #7ee787;
    border: none;
    font-family: &quot;Consolas&quot;;
    font-size: 9pt;
    selection-background-color: #1a3a5c;
    padding: 4px 8px;
}
QTabWidget::pane {
    border: none;
    background: #0d1117;
}
QTabBar::tab {
    background: #181b20;
    color: #4a5568;
    border: none;
    border-right: 1px solid #111418;
    border-bottom: 2px solid transparent;
    padding: 5px 14px;
    font-size: 9pt;
}
QTabBar::tab:selected {
    background: #1e2228;
    color: #c9d1d9;
    border-bottom: 2px solid #0078d4;
}
QTabBar::tab:hover:!selected {
    background: #2e3440;
    color: #8b949e;
}
QScrollBar:vertical {
    background: #1a1d22;
    width: 8px;
    border: none;
    margin: 0;
}
QScrollBar::handle:vertical {
    background: #2c313a;
    border-radius: 4px;
    min-height: 20px;
}
QScrollBar::handle:vertical:hover { background: #546070; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0; }
QScrollBar:horizontal {
    background: #1a1d22;
    height: 8px;
    border: none;
}
QScrollBar::handle:horizontal {
    background: #2c313a;
    border-radius: 4px;
    min-width: 20px;
}
QScrollBar::handle:horizontal:hover { background: #546070; }
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal { width: 0; }
QGroupBox {
    color: #4a5568;
    font-size: 8pt;
    font-weight: bold;
    border: none;
    border-top: 1px solid #2c313a;
    margin-top: 6px;
    padding-top: 8px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 10px;
    padding: 0 4px;
    color: #4a5568;
}
QDoubleSpinBox, QSpinBox {
    background-color: #181b20;
    color: #c9d1d9;
    border: 1px solid #2c313a;
    border-radius: 2px;
    padding: 2px 4px;
    font-family: &quot;Consolas&quot;;
    font-size: 9pt;
    min-width: 60px;
}
QDoubleSpinBox::up-button, QSpinBox::up-button,
QDoubleSpinBox::down-button, QSpinBox::down-button {
    background: #22262d;
    border: none;
    width: 14px;
}
QDoubleSpinBox::up-button:hover, QSpinBox::up-button:hover,
QDoubleSpinBox::down-button:hover, QSpinBox::down-button:hover {
    background: #0078d4;
}
QPushButton {
    background-color: #22262d;
    color: #8b949e;
    border: 1px solid #2c313a;
    border-radius: 3px;
    padding: 4px 12px;
    font-size: 9pt;
    min-height: 22px;
}
QPushButton:hover {
    background-color: #2e3440;
    border-color: #546070;
    color: #c9d1d9;
}
QPushButton:pressed {
    background-color: #0078d4;
    border-color: #005fa3;
    color: #ffffff;
}
QFrame[frameShape=&quot;4&quot;], QFrame[frameShape=&quot;5&quot;] {
    color: #2c313a;
    background: #2c313a;
}
