   <string notr="true">
QMainWindow {
    background-color: #1e1f22;
    color: #dfe1e5;
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, sans-serif;
    font-size: 13px;
}

/* ── SIDEBAR ── */
#sidebar {
    background-color: #1e1f22;
    border-right: 1px solid #2d2f33;
    min-width: 220px;
    max-width: 220px;
}

#sidebarLogo {
    background-color: transparent;
    padding: 18px 16px 10px 16px;
    border-bottom: 1px solid #2d2f33;
}

#logoLabel {
    color: #dfe1e5;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.2px;
    background: transparent;
}

#navList {
    background-color: transparent;
    border: none;
    outline: none;
    padding: 6px 0px;
    font-size: 13px;
    color: #dfe1e5;
}

#navList::item {
    height: 32px;
    padding-left: 16px;
    padding-right: 8px;
    border-radius: 0px;
    color: #9da0a8;
    border-left: 3px solid transparent;
}

#navList::item:selected {
    background-color: #2e436e;
    color: #dfe1e5;
    border-left: 3px solid #4e9fea;
}

#navList::item:hover:!selected {
    background-color: #2a2b2f;
    color: #dfe1e5;
    border-left: 3px solid transparent;
}

#sidebarSpacer {
    background: transparent;
    flex: 1;
}

#licenseWidget {
    background-color: transparent;
    padding: 12px 16px;
    border-top: 1px solid #2d2f33;
}

#licenseIcon {
    color: #5fad56;
    font-size: 13px;
}

#licenseLabel {
    color: #9da0a8;
    font-size: 12px;
    background: transparent;
}

#manageLicenseLabel {
    color: #4e9fea;
    font-size: 12px;
    background: transparent;
}

#manageLicenseLabel:hover {
    color: #6db3f2;
    text-decoration: underline;
}

/* ── MAIN CONTENT ── */
#mainContent {
    background-color: #2b2d30;
}

#settingsBtn {
    background: transparent;
    border: none;
    color: #9da0a8;
    font-size: 16px;
    padding: 6px 8px;
    border-radius: 4px;
    min-width: 28px;
    min-height: 28px;
}

#settingsBtn:hover {
    background-color: #393b40;
    color: #dfe1e5;
}

#contentScrollArea {
    background-color: #2b2d30;
    border: none;
}

#contentScrollArea QScrollBar:vertical {
    background: transparent;
    width: 8px;
    margin: 0;
}

#contentScrollArea QScrollBar::handle:vertical {
    background: #4a4d52;
    border-radius: 4px;
    min-height: 24px;
}

#contentScrollArea QScrollBar::handle:vertical:hover {
    background: #6b6e73;
}

#contentScrollArea QScrollBar::add-line:vertical,
#contentScrollArea QScrollBar::sub-line:vertical {
    height: 0;
}

#contentScrollArea QScrollBar::add-page:vertical,
#contentScrollArea QScrollBar::sub-page:vertical {
    background: transparent;
}

#contentInner {
    background-color: #2b2d30;
}

#welcomeTitle {
    color: #dfe1e5;
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.3px;
    background: transparent;
}

#welcomeSubtitle {
    color: #9da0a8;
    font-size: 13px;
    background: transparent;
}

#sectionLabel {
    color: #dfe1e5;
    font-size: 14px;
    font-weight: 600;
    background: transparent;
    margin-bottom: 4px;
}

/* ── GET STARTED CARDS ── */
#getStartedCard {
    background-color: #313438;
    border: 1px solid #3c3f41;
    border-radius: 4px;
    min-height: 110px;
}

#getStartedCard:hover {
    background-color: #383b3e;
    border: 1px solid #4e9fea;
}

#cardIconLabel {
    color: #4e9fea;
    font-size: 28px;
    background: transparent;
}

#cardTitleLabel {
    color: #dfe1e5;
    font-size: 14px;
    font-weight: 600;
    background: transparent;
}

#cardDescLabel {
    color: #9da0a8;
    font-size: 12px;
    background: transparent;
}

#cardArrow {
    color: #4e9fea;
    font-size: 16px;
    background: transparent;
}

/* ── RECENT PROJECTS ── */
#recentHeader {
    background: transparent;
}

#viewAllLabel {
    color: #4e9fea;
    font-size: 13px;
    background: transparent;
}

#viewAllLabel:hover {
    color: #6db3f2;
    text-decoration: underline;
}

#recentProjectsContainer {
    background-color: #313438;
    border: 1px solid #3c3f41;
    border-radius: 4px;
    padding: 0px;
}

#projectRow {
    background-color: transparent;
    border-bottom: 1px solid #3c3f41;
    min-height: 52px;
    max-height: 52px;
    padding: 0px 14px;
}

#projectRow:last-child {
    border-bottom: none;
}

#projectRow:hover {
    background-color: #383b3f;
}

#projectFileIcon {
    color: #6b6e73;
    font-size: 14px;
    background: transparent;
}

#projectName {
    color: #dfe1e5;
    font-size: 13px;
    font-family: &quot;JetBrains Mono&quot;, &quot;Consolas&quot;, &quot;Courier New&quot;, monospace;
    font-weight: 500;
    background: transparent;
}

#projectPath {
    color: #6b6e73;
    font-size: 11px;
    font-family: &quot;JetBrains Mono&quot;, &quot;Consolas&quot;, &quot;Courier New&quot;, monospace;
    background: transparent;
}

#projectDate {
    color: #6b6e73;
    font-size: 12px;
    background: transparent;
}

/* ── RIGHT PANEL ── */
#rightPanel {
    background-color: #2b2d30;
    border-left: 1px solid #2d2f33;
    min-width: 340px;
    max-width: 340px;
}

#rightPanelInner {
    background-color: #2b2d30;
}

#newsPanelCard {
    background-color: #313438;
    border: 1px solid #3c3f41;
    border-radius: 4px;
    padding: 14px;
}

#newsHeader {
    background: transparent;
}

#newsSectionLabel {
    color: #dfe1e5;
    font-size: 14px;
    font-weight: 600;
    background: transparent;
}

#newsViewAll {
    color: #4e9fea;
    font-size: 12px;
    background: transparent;
}

#newsViewAll:hover {
    color: #6db3f2;
    text-decoration: underline;
}

#newsDot {
    color: #4e9fea;
    font-size: 9px;
    background: transparent;
    margin-top: 2px;
}

#newsItemTitle {
    color: #dfe1e5;
    font-size: 13px;
    font-weight: 500;
    background: transparent;
}

#newsItemDate {
    color: #6b6e73;
    font-size: 11px;
    background: transparent;
}

#newsItemDesc {
    color: #9da0a8;
    font-size: 12px;
    background: transparent;
}

#newsDivider {
    color: #3c3f41;
    background: #3c3f41;
    border: none;
    height: 1px;
    margin: 8px 0px;
}

/* ── RESOURCE HUB ── */
#resourceCard {
    background-color: #313438;
    border: 1px solid #3c3f41;
    border-radius: 4px;
    padding: 14px;
}

#resourceSectionLabel {
    color: #dfe1e5;
    font-size: 14px;
    font-weight: 600;
    background: transparent;
    margin-bottom: 10px;
}

#resourceItem {
    background: transparent;
    border-radius: 3px;
    padding: 6px 4px;
}

#resourceItem:hover {
    background-color: #393b40;
}

#resourceIcon {
    color: #4e9fea;
    font-size: 18px;
    background: transparent;
    min-width: 28px;
}

#resourceTitle {
    color: #dfe1e5;
    font-size: 13px;
    font-weight: 500;
    background: transparent;
}

#resourceDesc {
    color: #9da0a8;
    font-size: 11px;
    background: transparent;
}

/* ── STATUS BAR ── */
#statusBar {
    background-color: #1e1f22;
    border-top: 1px solid #2d2f33;
    min-height: 28px;
    max-height: 28px;
    padding: 0px 14px;
}

#statusReadyLabel {
    color: #9da0a8;
    font-size: 12px;
    background: transparent;
}

#statusVersionLabel {
    color: #6b6e73;
    font-size: 12px;
    background: transparent;
}

#statusActionBtn {
    background: transparent;
    border: none;
    color: #9da0a8;
    font-size: 12px;
    padding: 0px 6px;
    border-radius: 2px;
}

#statusActionBtn:hover {
    background-color: #393b40;
    color: #dfe1e5;
}

#statusSep {
    color: #3c3f41;
    background: #3c3f41;
}
